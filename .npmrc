# Expo SDK 55 pins react-native@0.76.9, but react-native-screens@4.25.1 (pulled
# transitively by @react-navigation) declares a peer of react-native >=0.82.
# That conflict makes a strict `npm ci` / `npm install` fail with ERESOLVE.
# We deliberately run web/PWA only (Vite + react-native-web), so the native
# peer mismatch is inert. legacy-peer-deps makes installs deterministic and
# keeps CI (`npm ci`) green. Revisit if/when the native target is stood up.
legacy-peer-deps=true
