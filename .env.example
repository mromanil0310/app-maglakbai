# MaglakbAI environment variables — copy to `.env` and fill in.
# All vars are OPTIONAL: the app runs fully without them (analytics no-ops,
# Phase 2 backend features stay disabled). Vite only exposes vars prefixed VITE_.

# ─── Analytics (optional, opt-in) ────────────────────────────────────────────────
# PostHog project API key. When unset, track()/identify() are hard no-ops.
# Analytics also require the user's in-app consent before anything is sent.
VITE_POSTHOG_API_KEY=
# PostHog host (defaults to https://us.i.posthog.com when unset).
VITE_POSTHOG_HOST=

# ─── Phase 2 — Supabase backend (PLANNED, not yet implemented) ───────────────────
# See docs/ARCHITECTURE.md "Phase 2" and docs/DATABASE.md.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
